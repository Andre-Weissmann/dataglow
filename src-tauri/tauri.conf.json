{
  "$schema": "https://schema.tauri.app/config/1",
  "build": {
    "beforeDevCommand": "node scripts/stage-desktop-frontend.mjs",
    "beforeBuildCommand": "node scripts/stage-desktop-frontend.mjs",
    "devPath": "dist",
    "distDir": "dist",
    "withGlobalTauri": false
  },
  "package": {
    "productName": "DATAGLOW",
    "version": "1.0.0"
  },
  "tauri": {
    "allowlist": {
      "all": false
    },
    "bundle": {
      "active": true,
      "targets": "all",
      "identifier": "com.dataglow.app",
      "publisher": "DATAGLOW",
      "category": "Productivity",
      "shortDescription": "Your data, glowing.",
      "longDescription": "DATAGLOW — a zero-server, zero-upload data analytics workspace running entirely on your machine.",
      "icon": [
        "icons/32x32.png",
        "icons/128x128.png",
        "icons/128x128@2x.png",
        "icons/icon.icns",
        "icons/icon.ico"
      ],
      "resources": [],
      "externalBin": [],
      "copyright": "",
      "macOS": {
        "minimumSystemVersion": "10.13"
      },
      "windows": {
        "wix": {},
        "nsis": {}
      }
    },
    "security": {
      "csp": null
    },
    "updater": {
      "active": false
    },
    "windows": [
      {
        "title": "DATAGLOW",
        "width": 1280,
        "height": 832,
        "minWidth": 880,
        "minHeight": 600,
        "resizable": true,
        "fullscreen": false,
        "center": true
      }
    ]
  }
}
